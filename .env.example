# Server bind address.
HOST=127.0.0.1
PORT=3001

# Runtime mode. Keep development for local use; production disables permissive
# defaults such as local provider URLs unless explicitly configured.
NODE_ENV=development

# Logging level for the Fastify server.
LOG_LEVEL=info

# Comma-separated browser origins allowed to call the API directly.
# Leave blank when using the Vite dev proxy or same-origin deployment.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Local provider URLs are allowed by default outside production.
# Set false for stricter security testing, or true only when you intentionally
# need providers running on localhost during development.
ALLOW_LOCAL_PROVIDER_URLS=true

# Comma-separated provider origins that may resolve to private/reserved
# addresses. Entries must be exact http/https origins; wildcards, paths, and
# network ranges are not supported.
# Example: TRUSTED_PROVIDER_ORIGINS=https://www.right.codes
TRUSTED_PROVIDER_ORIGINS=

# Local SQLite database and generated result assets live here.
# Defaults to .image2-data in the current working directory when unset.
IMAGE2_DATA_DIR=.image2-data
