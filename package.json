{
  "name": "image2-tool",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,server -c green,cyan \"npm run dev -w @image2/web\" \"npm run dev -w @image2/server\"",
    "dev:web": "npm run dev -w @image2/web",
    "dev:server": "npm run dev -w @image2/server",
    "build": "npm run build -w @image2/shared && npm run build -w @image2/server && npm run build -w @image2/web",
    "lint": "eslint .",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.29.0",
    "globals": "^16.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.3"
  }
}
